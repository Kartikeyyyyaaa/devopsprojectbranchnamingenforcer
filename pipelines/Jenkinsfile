pipeline {
    agent any

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Branch to build')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'],
               description: 'Deployment environment')
    }

    environment {
        APP_NAME    = 'branch-enforcer'
        VERSION     = "${env.BUILD_ID}"
        DOCKER_IMG  = "${APP_NAME}:${env.BUILD_ID}"
        STUDENT     = 'Kartikeya Aryan Mishra – 23FE10CSE00736'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: "${params.BRANCH}",
                    url: 'https://github.com/kartikeya/devopsprojectbranchnamingenforcer.git'
                echo "📦  Checked out branch: ${params.BRANCH}"
            }
        }

        stage('Code Quality') {
            steps {
                script {
                    sh '''
                        pip install flake8 --quiet
                        flake8 src/main/python/ --max-line-length=100 --statistics || true
                    '''
                    echo "✅  Code quality check complete"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t ${DOCKER_IMG} -f infrastructure/docker/Dockerfile ."
                    echo "🐳  Docker image built: ${DOCKER_IMG}"
                }
            }
        }

        stage('Unit Tests') {
            steps {
                script {
                    sh '''
                        pip install pytest --quiet
                        pytest tests/unit/ -v --tb=short \
                            --junitxml=test-results/unit-results.xml
                    '''
                }
            }
            post {
                always {
                    junit 'test-results/unit-results.xml'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                script {
                    sh '''
                        pytest tests/integration/ -v --tb=short \
                            --junitxml=test-results/integration-results.xml
                    '''
                }
            }
            post {
                always {
                    junit 'test-results/integration-results.xml'
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    sh "trivy image --exit-code 0 --severity HIGH,CRITICAL ${DOCKER_IMG} || true"
                    echo "🔒  Security scan complete"
                }
            }
        }

        stage('Deploy – Staging') {
            when {
                expression { params.ENVIRONMENT == 'staging' }
            }
            steps {
                script {
                    sh '''
                        docker-compose -f infrastructure/docker/docker-compose.yml \
                            up -d branch-enforcer
                    '''
                    echo "🚀  Deployed to staging"
                }
            }
        }

        stage('Deploy – Production') {
            when {
                expression { params.ENVIRONMENT == 'prod' }
            }
            steps {
                input message: '🚨  Deploy to production?', ok: 'Deploy Now'
                script {
                    sh "kubectl apply -f infrastructure/kubernetes/"
                    echo "🏭  Deployed to production"
                }
            }
        }
    }

    post {
        success {
            echo "✅  Pipeline PASSED for ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            emailext(
                subject: "✅ Pipeline Passed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build succeeded.\nURL: ${env.BUILD_URL}\nStudent: ${STUDENT}",
                to: 'kartikeya@university.edu'
            )
        }
        failure {
            echo "❌  Pipeline FAILED"
            emailext(
                subject: "❌ Pipeline Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build failed. Check logs at: ${env.BUILD_URL}",
                to: 'kartikeya@university.edu'
            )
        }
        always {
            cleanWs()
        }
    }
}
